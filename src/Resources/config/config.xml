<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/master/src/Core/System/SystemConfig/Schema/config.xsd">
    <card>
        <title>General</title>
        <title lang="de-DE">Allgemein</title>

        <input-field type="bool">
            <name>specialCharSupport</name>
            <label>Enable support for special chars (like umlauts) in the Source URL</label>
            <label lang="de-DE">Unterstützung für spezielle Zeichen (wie Umlaute) in der Quell URL aktivieren</label>
            <defaultValue>false</defaultValue>
        </input-field>

    </card>

    <card>
        <title>Auto-Redirect for deactivated products</title>
        <title lang="de-DE">Auto-Redirect für deaktivierte Produkte</title>

        <component name="scop-platform-redirect-auto-redirect-config">
            <name>autoRedirectEnabled</name>
        </component>
    </card>

    <card>
        <title>Auto-Redirect for deleted products</title>
        <title lang="de-DE">Auto-Redirect für gelöschte Produkte</title>

        <component name="scop-platform-redirect-auto-redirect-delete-config">
            <name>autoRedirectOnDeleteEnabled</name>
        </component>
    </card>

    <card>
        <title>404 Errors</title>
        <title lang="de-DE">404-Fehler</title>

        <component name="scop-platform-redirect-not-found-config">
            <name>notFoundLogCleanupEnabled</name>
        </component>
    </card>

    <card>
        <title>URL Normalization</title>
        <title lang="de-DE">URL-Normalisierung</title>

        <input-field type="bool">
            <name>lowercaseUrlRedirect</name>
            <label>Redirect uppercase URLs to lowercase</label>
            <label lang="de-DE">Grossbuchstaben-URLs auf Kleinbuchstaben umleiten</label>
            <description>When enabled, URLs with uppercase letters are automatically redirected to their lowercase version (301) if a matching SEO URL exists.</description>
            <description lang="de-DE">Wenn aktiviert, werden URLs mit Grossbuchstaben automatisch auf die Kleinbuchstaben-Version weitergeleitet (301), falls eine passende SEO-URL existiert.</description>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

</config>
